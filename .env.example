# ============================================================
# SA Games Monitor — Configuração
# ============================================================

# URL do sitemap da loja (obrigatório)
SITEMAP_URL=https://mkgames2.lojavirtualnuvem.com.br/sitemap.xml

# Porta do servidor web (padrão: 3000)
PORT=3000

# Agendamento do cron (padrão: a cada 2 horas)
# Formato: minuto hora dia-mês mês dia-semana
MONITOR_CRON=0 */2 * * *

# Tamanho do lote de produtos por vez (padrão: 3)
BATCH_SIZE=3

# Estoque a definir quando produto estiver disponível (padrão: 10)
STOCK_IN_VALUE=10
